{
  "name": "@sero-ai/plugin-spotify",
  "version": "0.3.0",
  "description": "Spotify app for Sero — Web Playback SDK, playlist browsing, and agent tools",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p ui/tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ]
  },
  "sero": {
    "app": {
      "id": "spotify",
      "name": "Spotify",
      "icon": "music-2",
      "scope": "global",
      "stateFile": ".sero/apps/spotify/state.json",
      "ui": "./dist/ui/remoteEntry.js",
      "component": "SpotifyApp",
      "devPort": 5185
    },
    "plugin": {
      "category": "entertainment",
      "tags": [
        "spotify",
        "music",
        "playback",
        "streaming"
      ],
      "minSeroVersion": "0.1.0",
      "preBuilt": false
    },
    "widgets": [
      {
        "id": "mini-player",
        "name": "Mini Player",
        "component": "SpotifyWidget",
        "description": "Now playing with album art, progress bar, and playback controls",
        "defaultSize": {
          "w": 2,
          "h": 2
        },
        "minSize": {
          "w": 2,
          "h": 2
        },
        "maxSize": {
          "w": 3,
          "h": 3
        }
      }
    ]
  },
  "dependencies": {
    "typebox": "^1.1.37"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.78.0",
    "@earendil-works/pi-coding-agent": ">=0.78.0",
    "@earendil-works/pi-tui": ">=0.78.0",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.11.0",
    "@sero-ai/app-runtime": "^0.1.3",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
